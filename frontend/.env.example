# PRO HR — Frontend (Next.js). Copy to `.env.local` and adjust if needed.
# Repository: https://github.com/raviprateek2-dotcom/astral-cassini
#
# Recommended local dev: leave NEXT_PUBLIC_API_URL empty so the browser uses
# same-origin `/api/*`; Next rewrites those to BACKEND_URL.

BACKEND_URL=http://127.0.0.1:8000

# Optional: force the browser to call an absolute API origin (must be CORS-allowed on the API).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000

# Optional: UI-only demo (no API login, no cookie). Set on Vercel only for throwaway demos — never real production.
# NEXT_PUBLIC_DEMO_MODE=1
