# PRO HR Configuration — 10-Agent RAG Ecosystem
# Usage: Copy this to .env and fill in your keys

# --- Core API ---
APP_NAME=PRO HR
APP_PORT=8000
APP_DEBUG=true
FRONTEND_URL=http://localhost:3000

# --- Authentication ---
SECRET_KEY=generate_your_secure_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=600

# --- AI & Models ---
# OpenAI API Key is REQUIRED for RAG and Agentic Orchestration
OPENAI_API_KEY=sk-proj-your-actual-key-here
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Database & Storage ---
# Use an absolute path or relative to the app root in Docker (/app/data/dev.db)
DATABASE_URL=sqlite:///./data/dev.db
FAISS_INDEX_PATH=./data/faiss_index

# --- LangChain (Optional for Tracing) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=lsv2_pt_your_key_here
# LANGCHAIN_PROJECT=pro-hr-production
