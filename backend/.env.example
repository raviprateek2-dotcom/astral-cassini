# PRO HR — Backend configuration
# Copy to .env and set real values. See app/config.py for all Settings fields.

# --- Core API ---
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
# Origin users type in the browser (CORS + cookie expectations). Use http://localhost:3000 for default Docker Compose.
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated origins, e.g. https://app.example.com
# CORS_EXTRA_ORIGINS=

# --- Authentication ---
# JWT signing: 32+ characters, no leading/trailing whitespace in production
SECRET_KEY=replace_with_a_random_string_at_least_32_characters_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=600
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
# Production HTTPS: AUTH_COOKIE_SECURE=true
# Cross-site HTTPS: AUTH_COOKIE_SECURE=true AUTH_COOKIE_SAMESITE=none

# WebSocket tickets (Phase C): short-lived JWT for ?token= on /ws/{job_id}
# Keep legacy full-session JWT fallback OFF by default; only enable briefly as rollback.
# WS_TICKET_EXPIRE_MINUTES=15
# WS_ALLOW_LEGACY_BROWSER_TOKEN=false

# --- AI & models ---
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Calendar provider ---
# Use "mock" for local/dev. Set "google" only when credentials below are configured.
CALENDAR_PROVIDER=mock
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/google-service-account.json

# --- Email provider ---
# Use "mock" for local/dev. Set "smtp" to send real outbound emails.
EMAIL_PROVIDER=mock
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@your-company.com
# SMTP_USE_TLS=true

# --- Database ---
DATABASE_URL=sqlite:///./data/dev.db

# RAG: FAISS index directory is defined in code (default ./data/faiss_index under backend).

# Demo users (dev only; requires APP_ENV development/dev/local)
SEED_DEMO_USERS=false
DEMO_ADMIN_PASSWORD=
DEMO_HR_PASSWORD=

# --- Data retention ---
RETENTION_ENABLED=false
RETENTION_DAYS_COMPLETED_JOBS=30
RETENTION_MAX_JOBS=500

# --- LangSmith (optional) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=pro-hr
